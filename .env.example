# In-cluster / EduCloud defaults (used when running the dashboard inside Kubernetes)
MVD_CONSUMER_CP_URL=http://controlplane.consumer.svc.cluster.local:8080
MVD_PROVIDER_CP_URL=http://controlplane.provider.svc.cluster.local:8080
MVD_CONSUMER_DP_URL=http://dataplane.consumer.svc.cluster.local:8080
MVD_PROVIDER_DP_URL=http://dataplane.provider.svc.cluster.local:8080
MVD_PROVIDER_DSP_URL=http://controlplane.provider.svc.cluster.local:8082/api/dsp/2025-1
MVD_PROVIDER_ID=did:web:identityhub.provider.svc.cluster.local%3A7083:provider
MVD_CONSUMER_IH_URL=http://identityhub.consumer.svc.cluster.local:7083
MVD_PROVIDER_IH_URL=http://identityhub.provider.svc.cluster.local:7083
MVD_PROVIDER_VAULT_URL=http://vault.provider.svc.cluster.local:8200/v1/sys/health
MVD_ISSUER_URL=http://issuerservice.issuer.svc.cluster.local:8080/admin
MVD_TRAEFIK_URL=http://traefik.traefik.svc.cluster.local:80

# Local Traefik port-forward alternative (copy into Settings or .env.local):
# MVD_CONSUMER_CP_URL=http://cp.consumer.localhost
# MVD_PROVIDER_CP_URL=http://cp.provider.localhost
# MVD_CONSUMER_DP_URL=http://dp.consumer.localhost
# MVD_PROVIDER_DP_URL=http://dp.provider.localhost
# MVD_PROVIDER_DSP_URL=http://cp.provider.localhost/api/dsp/2025-1
# MVD_CONSUMER_IH_URL=http://ih.consumer.localhost/cs
# MVD_PROVIDER_IH_URL=http://ih.provider.localhost/cs
# MVD_PROVIDER_VAULT_URL=http://vault.provider.localhost/v1/sys/health
# MVD_ISSUER_URL=http://issuer.localhost/admin
# MVD_TRAEFIK_URL=http://localhost

# Default MVD demo API key from the Bruno collection. Replace for non-demo deployments.
MVD_API_KEY_HEADER=X-Api-Key
MVD_API_KEY_VALUE=password

# auto: call real services and fall back to mock responses when unavailable
# on: use mock responses only
# off: never use mock fallback
MVD_MOCK_MODE=off

# Pink Panther · dashboard metadata
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_CLUSTER_NAME=local-mvd
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_OTEL_ENDPOINT=
